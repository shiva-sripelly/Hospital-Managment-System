DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/hospital_management_db
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
OTP_EXPIRE_MINUTES=10
APP_ENV=development
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@hospital.local
SMTP_USE_TLS=true
SMTP_USE_SSL=false
